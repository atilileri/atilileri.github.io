---
// Footer component
---

<footer
  class="mt-32 pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8 px-12 pb-12"
>
  <div class="flex items-center gap-8">
    <span
      class="font-mono text-[10px] text-[var(--color-outline)] tracking-widest uppercase"
      >© 2024 VELOCITY PRECISION</span
    >
    <div class="flex gap-4">
      <a
        class="text-[var(--color-outline)] hover:text-[var(--color-primary-container)] transition-colors"
        href="#"
        aria-label="GitHub"
      >
        <span class="material-symbols-outlined text-lg">terminal</span>
      </a>
      <a
        class="text-[var(--color-outline)] hover:text-[var(--color-primary-container)] transition-colors"
        href="#"
        aria-label="Website"
      >
        <span class="material-symbols-outlined text-lg">public</span>
      </a>
      <a
        class="text-[var(--color-outline)] hover:text-[var(--color-primary-container)] transition-colors"
        href="#"
        aria-label="Code"
      >
        <span class="material-symbols-outlined text-lg">code</span>
      </a>
    </div>
  </div>
  <div class="flex items-center gap-1">
    <span
      class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"
    ></span>
    <span
      class="font-mono text-[10px] text-[var(--color-on-surface-variant)] uppercase tracking-tighter"
      >Systems Operational</span
    >
  </div>
</footer>
