---
/**
 * TerminalReplay.astro — PROTOTYPE (throwaway)
 * A pre-recorded terminal session that "types itself" — no server, no asciinema
 * dependency, just a timed script. Replays a Claude Code / skills session.
 */
const script = [
  { t: "cmd", text: "claude", pause: 500 },
  { t: "out", text: "✻ Welcome to Claude Code", pause: 250 },
  { t: "cmd", text: "> /wayfinder chart a web presentation for execs", pause: 700 },
  { t: "out", text: "◇ Charting the map — grilling for the destination…", pause: 500 },
  { t: "out", text: "◇ Created map #4 · 4 prototype tickets · 1 research ticket", pause: 500 },
  { t: "cmd", text: "> /prototype the astro-native option", pause: 700 },
  { t: "out", text: "◆ Building throwaway deck on prototype/astro-native-showcase", pause: 450 },
  { t: "out", text: "  ✓ hero · scroll-narrative · tokenizer · chart · code · terminal", pause: 450 },
  { t: "ok",  text: "  ✓ astro build → dist/ (fully static, GitHub-Pages ready)", pause: 400 },
  { t: "cmd", text: "> _", pause: 200, caret: true },
];
---
<div class="term" data-term>
  <div class="term__bar">
    <span class="dot dot--r"></span><span class="dot dot--y"></span><span class="dot dot--g"></span>
    <span class="term__title">zsh — claude-code — replay</span>
    <button class="term__replay" data-term-replay>↻ replay</button>
  </div>
  <pre class="term__screen" data-term-screen></pre>
  <script type="application/json" data-term-script set:html={JSON.stringify(script)}></script>
</div>

<style>
  .term {
    background: #0a0713; border: 1px solid #ffffff1f; border-radius: 14px;
    overflow: hidden; box-shadow: 0 30px 80px -30px #000, 0 0 0 1px #ffffff08;
    max-width: 820px; margin: 0 auto;
  }
  .term__bar {
    display: flex; align-items: center; gap: .5rem;
    padding: .6rem .9rem; background: #ffffff08; border-bottom: 1px solid #ffffff14;
  }
  .dot { width: 11px; height: 11px; border-radius: 999px; display: inline-block; }
  .dot--r { background: #ff5f56; } .dot--y { background: #ffbd2e; } .dot--g { background: #27c93f; }
  .term__title { color: var(--dim); font-family: var(--font-mono); font-size: .72rem; margin-left: .5rem; }
  .term__replay {
    margin-left: auto; background: #ffffff12; color: var(--ink); border: 1px solid #ffffff26;
    border-radius: 8px; padding: .2rem .6rem; font-family: var(--font-mono); font-size: .72rem; cursor: pointer;
  }
  .term__replay:hover { background: #ffffff22; }
  .term__screen {
    margin: 0; padding: 1.1rem 1.2rem; min-height: 300px;
    font-family: var(--font-mono); font-size: .92rem; line-height: 1.6;
    color: #d7d0f0; white-space: pre-wrap; word-break: break-word;
  }
  .line--cmd { color: #fff; }
  .line--cmd .prompt { color: var(--accent); }
  .line--out { color: #b9b0dc; }
  .line--ok { color: var(--accent3); }
  .caret::after {
    content: "▋"; color: var(--accent); animation: blink 1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
</style>

<script>
  function initTerminals() {
    document.querySelectorAll<HTMLElement>("[data-term]").forEach((root) => {
      const screen = root.querySelector<HTMLElement>("[data-term-screen]");
      const data = root.querySelector<HTMLElement>("[data-term-script]");
      const replayBtn = root.querySelector<HTMLButtonElement>("[data-term-replay]");
      if (!screen || !data) return;
      const steps = JSON.parse(data.textContent || "[]") as {
        t: string; text: string; pause: number; caret?: boolean;
      }[];

      let timers: number[] = [];
      const sleep = (ms: number) =>
        new Promise<void>((r) => timers.push(window.setTimeout(r, ms)));

      async function typeLine(text: string, cls: string, caret?: boolean) {
        const line = document.createElement("div");
        line.className = "line line--" + cls;
        screen!.appendChild(line);
        if (cls === "cmd") {
          const p = document.createElement("span");
          p.className = "prompt";
          line.appendChild(p);
        }
        const holder = document.createElement("span");
        line.appendChild(holder);
        for (const ch of text) {
          holder.textContent += ch;
          screen!.scrollTop = screen!.scrollHeight;
          await sleep(cls === "cmd" ? 34 : 8);
        }
        if (caret) line.classList.add("caret");
      }

      async function run() {
        timers.forEach(clearTimeout);
        timers = [];
        screen!.textContent = "";
        for (const s of steps) {
          await typeLine(s.text, s.t, s.caret);
          await sleep(s.pause);
        }
      }

      replayBtn?.addEventListener("click", run);

      // autoplay when it scrolls into view (once)
      let played = false;
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !played) { played = true; run(); }
        });
      }, { threshold: 0.5 });
      io.observe(root);
    });
  }
  document.addEventListener("astro:page-load", initTerminals);
</script>
