---
/**
 * PipelineVisualizer.astro
 * An elegant, interactive visualization of the Blogger AI pipeline.
 */
---

<section class="pipeline-section mt-4 mb-12 relative overflow-hidden rounded-2xl bg-[var(--color-surface-container-low)]/50 border border-[var(--color-outline-variant)]/10 p-6">
  <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="px-2 py-0.5 rounded-full bg-[var(--color-primary-container)]/10 text-[var(--color-primary-container)] text-[9px] font-bold tracking-widest uppercase">The Engine</span>
        <a href="https://github.com/atilileri/blogger" target="_blank" class="flex items-center gap-1 text-[var(--color-outline)] hover:text-[var(--color-primary-container)] transition-colors text-[10px] font-medium">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          atilileri/blogger
        </a>
      </div>
      <h2 class="font-[Space_Grotesk] text-xl font-bold tracking-tight">
        Automated <span class="text-[var(--color-primary-container)]">AI Content Forge</span>
      </h2>
    </div>
    <p class="text-[var(--color-on-surface-variant)] text-[11px] max-w-sm font-light leading-relaxed hidden md:block">
      Multi-agent <strong>LangGraph</strong> pipeline transforming raw URLs into bilingual blog posts with HitL validation.
    </p>
  </div>

  <div class="pipeline-canvas relative min-h-[350px] md:min-h-[280px] w-full flex items-center justify-center overflow-x-auto overflow-y-hidden pb-4 pt-4">
    <!-- SVG Connections Container -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none" id="pipeline-svg">
      <defs>
        <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="var(--color-primary-container)" fill-opacity="0.5" />
        </marker>
        <filter id="glow">
          <feGaussianBlur stdDeviation="1.5" result="coloredBlur"/>
          <feMerge>
            <feMergeNode in="coloredBlur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>
      <g id="connections-group" fill="none"></g>
    </svg>

    <!-- Horizontal Flow -->
    <div class="nodes-container relative flex flex-col md:flex-row items-center gap-12 md:gap-6 w-full max-w-6xl mx-auto z-10 px-8">
      
      <!-- Intake -->
      <div class="node-item intake" data-id="intake" data-title="Intake Node" data-desc="The entry point of the pipeline. It handles incoming Telegram webhooks, validates user permissions, and enqueues tasks into Redis RQ. It's designed to handle both YouTube transcripts and arbitrary web content.">
        <div class="node-icon"><span class="material-symbols-outlined text-lg">input</span></div>
        <div class="node-label">Intake</div>
      </div>

      <!-- Parallel Box -->
      <div class="relative flex flex-row gap-3 p-4 border border-dashed border-[var(--color-outline-variant)]/20 rounded-2xl bg-[var(--color-surface-container-lowest)]/30 group/parallel">
        <div class="absolute -top-2.5 left-4 px-2 bg-[var(--color-surface)] text-[8px] font-black text-[var(--color-outline)] uppercase tracking-widest border border-[var(--color-outline-variant)]/10 rounded-full">Parallel Extraction</div>
        <div class="node-item mini" data-id="trans" data-title="Whisper Transcription" data-desc="Utilizes Faster-Whisper (a reimplementation of OpenAI's Whisper) to transcribe video audio with extreme speed and accuracy. It processes multi-lingual audio and outputs structured text.">
          <span class="material-symbols-outlined text-base">transcribe</span>
        </div>
        <div class="node-item mini" data-id="writer" data-title="Technical Writer" data-desc="A Gemini-powered agent that specializes in extracting technical details, code snippets, and architectural patterns from web content. It focuses on precision and developer-centric insights.">
          <span class="material-symbols-outlined text-base">history_edu</span>
        </div>
        <div class="node-item mini" data-id="reader" data-tooltip="Summary Reader" data-title="Summary Reader" data-desc="Focuses on the narrative and high-level takeaways. It distills complex articles into digestible summaries, ensuring the 'Uncommon Sense' philosophy is preserved in the final output.">
          <span class="material-symbols-outlined text-base">auto_stories</span>
        </div>
      </div>

      <!-- Gather -->
      <div class="node-item tiny" data-id="gather" data-title="Gather Results" data-desc="A synchronization node that waits for all parallel extraction paths to complete. It merges the technical findings, transcriptions, and summaries into a unified state for downstream processing.">
        <span class="material-symbols-outlined text-sm">join_inner</span>
      </div>

      <!-- HitL Agent Chain -->
      <div class="flex flex-row gap-3">
        <div class="node-item agent hitl" data-id="ref" data-title="Reference Agent" data-desc="The first agentic step. It cross-references the gathered data with internal context and previous notes. Requires human approval via Telegram before proceeding.">
          <div class="node-icon"><span class="material-symbols-outlined text-sm">psychology</span></div>
          <div class="node-label">Ref</div>
        </div>
        <div class="node-item agent hitl" data-id="research" data-title="Research Agent" data-desc="Powered by Tavily, this agent performs live web searches to verify claims, find missing data, or provide broader context. It acts as an autonomous fact-checker with a human-in-the-loop.">
          <div class="node-icon"><span class="material-symbols-outlined text-sm">travel_explore</span></div>
          <div class="node-label">Res</div>
        </div>
        <div class="node-item agent hitl" data-id="creative" data-title="Creative Agent" data-desc="The storyteller. It takes the research and technical notes to craft compelling storylines. It provides multiple narrative options to the user for selection.">
          <div class="node-icon"><span class="material-symbols-outlined text-sm">auto_awesome</span></div>
          <div class="node-label">Cre</div>
        </div>
      </div>

      <!-- Finalization -->
      <div class="flex flex-row gap-3">
        <div class="node-item final" data-id="visual" data-title="Visual Node" data-desc="Generates the hero image for the post using Pollinations.ai. It crafts unique prompts based on the selected storyline to ensure a cohesive visual identity.">
          <div class="node-icon"><span class="material-symbols-outlined text-sm">palette</span></div>
          <div class="node-label">Vis</div>
        </div>
        <div class="node-item final" data-id="gitops" data-title="GitOps Node" data-desc="The deployment arm. It performs an atomic commit to the GitHub repository, including the Markdown content and generated images, triggering the Astro build pipeline.">
          <div class="node-icon"><span class="material-symbols-outlined text-sm">terminal</span></div>
          <div class="node-label">Git</div>
        </div>
      </div>

      <!-- Success -->
      <div class="node-item success kinetic-gradient" data-id="success" data-title="Live Deployment" data-desc="Success! The blog post is now live, translated into English and Turkish, and linked to the original sources. A truly 'automagical' process from URL to URL.">
        <div class="node-icon pulse"><span class="material-symbols-outlined text-lg">rocket_launch</span></div>
        <div class="node-label">Live</div>
      </div>

    </div>
  </div>

  <!-- Detail Panel (Side Drawer / Bottom Sheet) -->
  <div id="node-detail-panel" class="fixed inset-y-0 right-0 w-full md:w-80 bg-[var(--color-surface)]/95 backdrop-blur-xl border-l border-[var(--color-outline-variant)]/20 shadow-2xl translate-x-full transition-transform duration-500 ease-in-out z-[100] flex flex-col">
    <div class="p-6 flex items-center justify-between border-b border-[var(--color-outline-variant)]/10">
      <div class="flex items-center gap-3">
        <div id="panel-icon" class="w-10 h-10 rounded-xl bg-[var(--color-primary-container)]/10 text-[var(--color-primary-container)] flex items-center justify-center"></div>
        <h3 id="panel-title" class="font-[Space_Grotesk] text-lg font-bold">Node Detail</h3>
      </div>
      <button id="close-panel" class="w-8 h-8 rounded-full hover:bg-[var(--color-surface-container-high)] flex items-center justify-center transition-colors">
        <span class="material-symbols-outlined text-lg">close</span>
      </button>
    </div>
    <div class="p-8 overflow-y-auto flex-1">
      <div id="panel-desc" class="text-[var(--color-on-surface-variant)] text-sm leading-relaxed font-light"></div>
      <div class="mt-12 p-4 rounded-xl bg-[var(--color-surface-container-low)] border border-[var(--color-outline-variant)]/10">
        <h4 class="text-[10px] font-bold text-[var(--color-outline)] uppercase tracking-widest mb-2">Technical Specs</h4>
        <div class="space-y-2" id="panel-specs">
          <div class="flex justify-between items-center text-[10px]">
            <span class="text-[var(--color-outline)]">Status</span>
            <span class="text-green-600 font-bold">Production Ready</span>
          </div>
          <div class="flex justify-between items-center text-[10px]">
            <span class="text-[var(--color-outline)]">Latency</span>
            <span class="font-mono">&lt; 500ms</span>
          </div>
        </div>
      </div>
    </div>
    <div class="p-6 bg-[var(--color-surface-container-low)]/50">
      <a href="https://github.com/atilileri/blogger" target="_blank" class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-[var(--color-primary-container)] text-white text-xs font-bold hover:opacity-90 transition-opacity">
        <span class="material-symbols-outlined text-sm">code</span>
        VIEW SOURCE ON GITHUB
      </a>
    </div>
  </div>
  <div id="panel-overlay" class="fixed inset-0 bg-black/20 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-500 z-[90]"></div>

  <div id="pipeline-tooltip" class="fixed pointer-events-none bg-[var(--color-inverse-surface)] text-[var(--color-inverse-on-surface)] text-[9px] px-2 py-1.5 rounded-md opacity-0 transition-opacity duration-200 z-[100] shadow-lg max-w-[150px] font-medium hidden md:block"></div>
</section>

<style>
  @reference "../styles/global.css";

  .pipeline-section {
    perspective: 1000px;
  }

  .node-item {
    @apply flex flex-col items-center gap-1 bg-[var(--color-surface)] border border-[var(--color-outline-variant)]/20 p-2 rounded-xl shadow-sm transition-all duration-300 relative min-w-[64px] cursor-pointer;
    z-index: 20;
  }

  .node-item.mini {
    @apply p-1.5 min-w-[44px] rounded-lg bg-[var(--color-surface-container-high)]/50 border-none;
  }

  .node-item.tiny {
    @apply p-1 min-w-[34px] rounded-full border-none bg-transparent shadow-none;
  }

  .node-item:hover:not(.tiny) {
    @apply border-[var(--color-primary-container)]/50 shadow-md scale-[1.1];
    background: color-mix(in srgb, var(--color-surface), var(--color-primary-container) 8%);
  }

  .node-icon {
    @apply w-8 h-8 flex-shrink-0 flex items-center justify-center rounded-lg bg-[var(--color-surface-container-high)] text-[var(--color-primary-container)] transition-transform duration-300;
  }

  .node-item:hover .node-icon {
    @apply scale-110;
  }

  .node-label {
    @apply font-[Space_Grotesk] text-[10px] font-bold tracking-tight text-[var(--color-on-surface)] m-0 leading-none text-center;
  }

  /* Specific Styles */
  .node-item.hitl {
    @apply border-orange-500/20;
  }
  .node-item.hitl .node-icon {
    @apply bg-orange-500/5 text-orange-600;
  }

  .node-item.success {
    @apply border-none text-white;
  }
  .node-item.success .node-icon {
    @apply bg-white/10 text-white;
  }
  .node-item.success .node-label { @apply text-white; }

  .pulse {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.2); }
    70% { transform: scale(1.1); box-shadow: 0 0 0 6px rgba(255, 255, 255, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
  }

  /* Kinetic Gradient */
  .kinetic-gradient {
    background: linear-gradient(135deg, var(--color-primary-container) 0%, #002e6e 100%);
    background-size: 200% 200%;
    animation: gradientShift 5s ease infinite;
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Connection Lines */
  .flow-line {
    fill: none !important;
    stroke: var(--color-outline-variant);
    stroke-width: 0.8;
    opacity: 0.15;
  }

  .flow-line.active {
    stroke: var(--color-primary-container);
    opacity: 0.5;
    stroke-dasharray: 4, 12;
    stroke-dashoffset: 100;
    animation: flow 5s linear infinite;
    filter: url(#glow);
  }

  @keyframes flow {
    to { stroke-dashoffset: 0; }
  }

  /* Detail Panel */
  #node-detail-panel.active {
    @apply translate-x-0;
  }
  #panel-overlay.active {
    @apply opacity-100 pointer-events-auto;
  }

  @media (max-width: 768px) {
    .pipeline-canvas {
      @apply min-h-[550px];
    }
    #node-detail-panel {
      @apply top-auto h-[60vh] translate-y-full translate-x-0 rounded-t-3xl border-l-0 border-t;
    }
    #node-detail-panel.active {
      @apply translate-y-0;
    }
  }
</style>

<script>
  function initPipeline() {
    const svg = document.getElementById('pipeline-svg') as unknown as SVGSVGElement;
    const group = document.getElementById('connections-group');
    const tooltip = document.getElementById('pipeline-tooltip');
    const panel = document.getElementById('node-detail-panel');
    const overlay = document.getElementById('panel-overlay');
    const closeBtn = document.getElementById('close-panel');
    
    if (!svg || !group || !tooltip || !panel || !overlay || !closeBtn) return;

    const connections = [
      { from: 'intake', to: 'trans' },
      { from: 'intake', to: 'writer' },
      { from: 'intake', to: 'reader' },
      { from: 'trans', to: 'gather' },
      { from: 'writer', to: 'gather' },
      { from: 'reader', to: 'gather' },
      { from: 'gather', to: 'ref' },
      { from: 'ref', to: 'research' },
      { from: 'research', to: 'creative' },
      { from: 'creative', to: 'visual' },
      { from: 'creative', to: 'gitops' },
      { from: 'visual', to: 'success' },
      { from: 'gitops', to: 'success' },
    ];

    function drawConnections() {
      group!.innerHTML = '';
      const svgRect = svg.getBoundingClientRect();

      connections.forEach(conn => {
        const fromEl = document.querySelector(`[data-id="${conn.from}"]`);
        const toEl = document.querySelector(`[data-id="${conn.to}"]`);

        if (fromEl && toEl) {
          const fRect = fromEl.getBoundingClientRect();
          const tRect = toEl.getBoundingClientRect();

          const x1 = (fRect.left + fRect.width / 2) - svgRect.left;
          const y1 = (fRect.top + fRect.height / 2) - svgRect.top;
          const x2 = (tRect.left + tRect.width / 2) - svgRect.left;
          const y2 = (tRect.top + tRect.height / 2) - svgRect.top;

          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          const midX = (x1 + x2) / 2;
          const d = `M ${x1} ${y1} C ${midX} ${y1}, ${midX} ${y2}, ${x2} ${y2}`;
          
          path.setAttribute('d', d);
          path.setAttribute('class', 'flow-line');
          path.setAttribute('fill', 'none');
          path.setAttribute('marker-end', 'url(#arrowhead)');
          group!.appendChild(path);

          const activePath = path.cloneNode() as SVGPathElement;
          activePath.classList.add('active');
          group!.appendChild(activePath);
        }
      });
    }

    // Interaction Logic
    const nodes = document.querySelectorAll('.node-item');
    nodes.forEach(node => {
      node.addEventListener('mouseenter', (e) => {
        const msg = (node as HTMLElement).getAttribute('data-tooltip');
        if (msg) {
          tooltip.textContent = msg;
          tooltip.style.opacity = '1';
        }
      });

      node.addEventListener('mousemove', (e: any) => {
        tooltip.style.left = `${e.clientX + 15}px`;
        tooltip.style.top = `${e.clientY + 15}px`;
      });

      node.addEventListener('mouseleave', () => {
        tooltip.style.opacity = '0';
      });

      node.addEventListener('click', () => {
        const title = node.getAttribute('data-title');
        const desc = node.getAttribute('data-desc');
        const iconHtml = node.querySelector('.node-icon')?.innerHTML || node.innerHTML;

        if (title && desc) {
          (document.getElementById('panel-title') as HTMLElement).textContent = title;
          (document.getElementById('panel-desc') as HTMLElement).innerHTML = desc;
          (document.getElementById('panel-icon') as HTMLElement).innerHTML = iconHtml;
          
          panel.classList.add('active');
          overlay.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    const closePanel = () => {
      panel.classList.remove('active');
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    };

    closeBtn.addEventListener('click', closePanel);
    overlay.addEventListener('click', closePanel);

    // Initial draw
    setTimeout(drawConnections, 100);
    window.addEventListener('resize', drawConnections);
    document.addEventListener('astro:page-load', drawConnections);
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) drawConnections();
      });
    }, { threshold: 0.1 });
    observer.observe(svg);
  }

  document.addEventListener('DOMContentLoaded', initPipeline);
  document.addEventListener('astro:page-load', initPipeline);
  if (document.readyState === 'interactive' || document.readyState === 'complete') initPipeline();
</script>
