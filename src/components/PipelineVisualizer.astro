---
/**
 * PipelineVisualizer.astro
 * An elegant, interactive visualization of the Blogger AI pipeline.
 */
---

<section class="pipeline-section mt-8 mb-24 relative overflow-hidden rounded-3xl bg-[var(--color-surface-container-low)] border border-[var(--color-outline-variant)]/20 p-8 md:p-12">
  <div class="flex flex-col md:flex-row justify-between items-start mb-12 gap-6">
    <div class="max-w-2xl">
      <div class="flex items-center gap-2 mb-4">
        <span class="px-3 py-1 rounded-full bg-[var(--color-primary-container)] text-[var(--color-on-primary-fixed)] text-[10px] font-bold tracking-[0.2em] uppercase">Engine Architecture</span>
        <a href="https://github.com/atilileri/blogger" target="_blank" class="flex items-center gap-1.5 text-[var(--color-outline)] hover:text-[var(--color-primary-container)] transition-colors text-xs font-medium">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          View Source
        </a>
      </div>
      <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold tracking-tight mb-4">
        The "Automagical" <span class="text-[var(--color-primary-container)]">Content Forge</span>
      </h2>
      <p class="text-[var(--color-on-surface-variant)] text-sm md:text-base font-light leading-relaxed">
        A multi-agent autonomous pipeline built with <span class="font-semibold">LangGraph</span>. It transforms raw YouTube and web URLs into high-fidelity, bilingual blog posts with human-in-the-loop validation via Telegram.
      </p>
    </div>
  </div>

  <div class="pipeline-canvas relative min-h-[600px] w-full flex items-center justify-center overflow-x-auto pb-12">
    <!-- SVG Connections Container -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none" id="pipeline-svg">
      <defs>
        <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
          <polygon points="0 0, 10 3.5, 0 7" fill="var(--color-primary-container)" />
        </marker>
        <filter id="glow">
          <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
          <feMerge>
            <feMergeNode in="coloredBlur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>
      <g id="connections-group"></g>
    </svg>

    <!-- Nodes Container -->
    <div class="nodes-container relative flex flex-col items-center gap-16 w-full max-w-4xl mx-auto z-10">
      
      <!-- Entry Node -->
      <div class="node-item intake" data-id="intake" data-tooltip="Ingests YouTube transcripts and Website URLs via Telegram Bot webhook.">
        <div class="node-icon"><span class="material-symbols-outlined">input</span></div>
        <div class="node-content">
          <h3>Intake Node</h3>
          <p>Multi-source ingestion</p>
        </div>
      </div>

      <!-- Parallel Layer -->
      <div class="relative w-full border-2 border-dashed border-[var(--color-outline-variant)]/20 rounded-3xl p-8 bg-[var(--color-surface-container-lowest)]/50">
        <div class="absolute -top-3 left-6 px-3 py-0.5 bg-[var(--color-surface)] border border-[var(--color-outline-variant)]/30 rounded-full text-[10px] font-bold tracking-widest text-[var(--color-outline)] uppercase">Parallel Processing</div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="node-item parallel" data-id="trans" data-tooltip="Uses Faster-Whisper to transcribe audio content with high precision.">
            <div class="node-icon"><span class="material-symbols-outlined">transcribe</span></div>
            <div class="node-content">
              <h3>Whisper</h3>
              <p>Transcription</p>
            </div>
          </div>
          <div class="node-item parallel" data-id="writer" data-tooltip="Gemini-powered technical analysis focusing on architecture and code.">
            <div class="node-icon"><span class="material-symbols-outlined">history_edu</span></div>
            <div class="node-content">
              <h3>Tech Writer</h3>
              <p>Deep Analysis</p>
            </div>
          </div>
          <div class="node-item parallel" data-id="reader" data-tooltip="Extracts key insights and summaries from long-form web articles.">
            <div class="node-icon"><span class="material-symbols-outlined">auto_stories</span></div>
            <div class="node-content">
              <h3>Summary</h3>
              <p>Key Takeaways</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sync Node -->
      <div class="node-item gather" data-id="gather" data-tooltip="Synchronizes parallel outputs into a unified state for the agentic chain.">
        <div class="node-icon"><span class="material-symbols-outlined">join_inner</span></div>
        <div class="node-content">
          <h3>Gather</h3>
          <p>State Sync</p>
        </div>
      </div>

      <!-- HitL Agent Layer (Sequential) -->
      <div class="flex flex-col gap-12 items-center w-full">
        <div class="node-item agent hitl" data-id="ref" data-tooltip="Reference Agent: Links gathered data with internal context. Requires User Approval.">
          <div class="node-icon"><span class="material-symbols-outlined">psychology</span></div>
          <div class="node-content">
            <h3>Reference</h3>
            <p>Context Agent</p>
          </div>
          <div class="hitl-badge">HitL</div>
        </div>
        <div class="node-item agent hitl" data-id="research" data-tooltip="Research Agent: Uses Tavily API to verify facts and gather missing data. Requires User Approval.">
          <div class="node-icon"><span class="material-symbols-outlined">travel_explore</span></div>
          <div class="node-content">
            <h3>Research</h3>
            <p>Tavily Search</p>
          </div>
          <div class="hitl-badge">HitL</div>
        </div>
        <div class="node-item agent hitl" data-id="creative" data-tooltip="Creative Agent: Generates story arcs and bilingual content. User selects final narrative.">
          <div class="node-icon"><span class="material-symbols-outlined">auto_awesome</span></div>
          <div class="node-content">
            <h3>Creative</h3>
            <p>Storylining</p>
          </div>
          <div class="hitl-badge">HitL</div>
        </div>
      </div>

      <!-- Finalization Layer (Sequential) -->
      <div class="flex flex-col gap-12 items-center w-full">
        <div class="node-item final" data-id="visual" data-tooltip="Generates hero images via Pollinations.ai based on creative prompts.">
          <div class="node-icon"><span class="material-symbols-outlined">palette</span></div>
          <div class="node-content">
            <h3>Visual</h3>
            <p>AI Hero Image</p>
          </div>
        </div>
        <div class="node-item final" data-id="gitops" data-tooltip="Atomic commit to GitHub repository using GitOps principles.">
          <div class="node-icon"><span class="material-symbols-outlined">terminal</span></div>
          <div class="node-content">
            <h3>GitOps</h3>
            <p>GitHub Commit</p>
          </div>
        </div>
      </div>

      <!-- Output Node -->
      <div class="node-item success kinetic-gradient" data-id="success" data-tooltip="Pipeline complete! The post is live and translated in EN/TR.">
        <div class="node-icon pulse"><span class="material-symbols-outlined">rocket_launch</span></div>
        <div class="node-content">
          <h3>Success</h3>
          <p>Blog Live!</p>
        </div>
      </div>

    </div>
  </div>

  <div id="pipeline-tooltip" class="fixed pointer-events-none bg-[var(--color-inverse-surface)] text-[var(--color-inverse-on-surface)] text-[10px] px-3 py-2 rounded-lg opacity-0 transition-opacity duration-200 z-[100] shadow-xl max-w-[200px]"></div>

  <div class="mt-8 flex flex-wrap gap-4 justify-center md:justify-start">
    <div class="flex items-center gap-2 text-[var(--color-outline)] text-xs">
      <span class="w-2 h-2 rounded-full bg-[var(--color-primary-container)]"></span>
      Automated Flow
    </div>
    <div class="flex items-center gap-2 text-[var(--color-outline)] text-xs">
      <span class="w-2 h-2 rounded-full bg-orange-500"></span>
      Human-in-the-Loop
    </div>
    <div class="flex items-center gap-2 text-[var(--color-outline)] text-xs">
      <span class="w-2 h-2 rounded-full bg-green-500"></span>
      Success Output
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .pipeline-section {
    perspective: 1000px;
  }

  .node-item {
    @apply flex items-center gap-4 bg-[var(--color-surface)] border border-[var(--color-outline-variant)]/30 p-4 rounded-2xl shadow-sm transition-all duration-300 relative min-w-[180px] cursor-default;
    z-index: 20;
  }

  .node-item:hover {
    @apply border-[var(--color-primary-container)]/50 shadow-lg scale-[1.05];
    background: color-mix(in srgb, var(--color-surface), var(--color-primary-container) 5%);
  }

  .node-icon {
    @apply w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-xl bg-[var(--color-surface-container-high)] text-[var(--color-primary-container)] transition-transform duration-300;
  }

  .node-item:hover .node-icon {
    @apply scale-110;
  }

  .node-content h3 {
    @apply font-[Space_Grotesk] text-xs font-bold tracking-tight text-[var(--color-on-surface)] m-0 leading-none mb-1;
  }

  .node-content p {
    @apply text-[10px] text-[var(--color-outline)] m-0 leading-none;
  }

  /* Specific Styles */
  .node-item.hitl {
    @apply border-orange-500/20;
  }
  .node-item.hitl .node-icon {
    @apply bg-orange-500/10 text-orange-600;
  }
  .hitl-badge {
    @apply absolute -top-2 -right-2 bg-orange-500 text-white text-[8px] font-bold px-2 py-0.5 rounded-full shadow-sm;
  }

  .node-item.success {
    @apply border-none text-white;
  }
  .node-item.success .node-icon {
    @apply bg-white/20 text-white;
  }
  .node-item.success h3 { @apply text-white; }
  .node-item.success p { @apply text-white/70; }

  .pulse {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4); }
    70% { transform: scale(1.1); box-shadow: 0 0 0 10px rgba(255, 255, 255, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
  }

  /* Kinetic Gradient from main styles */
  .kinetic-gradient {
    background: linear-gradient(135deg, var(--color-primary-container) 0%, #002e6e 100%);
    background-size: 200% 200%;
    animation: gradientShift 5s ease infinite;
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Connection Animation */
  .flow-line {
    fill: none;
    stroke: var(--color-outline-variant);
    stroke-width: 1.5;
    opacity: 0.15;
  }

  .flow-line.active {
    stroke: var(--color-primary-container);
    opacity: 0.6;
    stroke-dasharray: 5, 10;
    stroke-dashoffset: 100;
    animation: flow 3s linear infinite;
    filter: url(#glow);
  }

  @keyframes flow {
    to { stroke-dashoffset: 0; }
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .pipeline-canvas {
      @apply min-h-[1400px] pt-8;
    }
    .node-item {
      @apply min-w-full;
    }
  }
</style>

<script>
  function initPipeline() {
    const svg = document.getElementById('pipeline-svg') as unknown as SVGSVGElement;
    const group = document.getElementById('connections-group');
    const tooltip = document.getElementById('pipeline-tooltip');
    if (!svg || !group || !tooltip) return;

    const connections = [
      { from: 'intake', to: 'trans' },
      { from: 'intake', to: 'writer' },
      { from: 'intake', to: 'reader' },
      { from: 'trans', to: 'gather' },
      { from: 'writer', to: 'gather' },
      { from: 'reader', to: 'gather' },
      { from: 'gather', to: 'ref' },
      { from: 'ref', to: 'research' },
      { from: 'research', to: 'creative' },
      { from: 'creative', to: 'visual' },
      { from: 'creative', to: 'gitops' },
      { from: 'visual', to: 'success' },
      { from: 'gitops', to: 'success' },
    ];

    function drawConnections() {
      group!.innerHTML = '';
      const svgRect = svg.getBoundingClientRect();

      connections.forEach(conn => {
        const fromEl = document.querySelector(`[data-id="${conn.from}"]`);
        const toEl = document.querySelector(`[data-id="${conn.to}"]`);

        if (fromEl && toEl) {
          const fRect = fromEl.getBoundingClientRect();
          const tRect = toEl.getBoundingClientRect();

          const x1 = (fRect.left + fRect.width / 2) - svgRect.left;
          const y1 = (fRect.top + fRect.height / 2) - svgRect.top;
          const x2 = (tRect.left + tRect.width / 2) - svgRect.left;
          const y2 = (tRect.top + tRect.height / 2) - svgRect.top;

          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          const midY = (y1 + y2) / 2;
          const d = `M ${x1} ${y1} C ${x1} ${midY}, ${x2} ${midY}, ${x2} ${y2}`;
          
          path.setAttribute('d', d);
          path.setAttribute('class', 'flow-line');
          path.setAttribute('marker-end', 'url(#arrowhead)');
          group!.appendChild(path);

          const activePath = path.cloneNode() as SVGPathElement;
          activePath.classList.add('active');
          group!.appendChild(activePath);
        }
      });
    }

    // Tooltip Logic
    const nodes = document.querySelectorAll('.node-item');
    nodes.forEach(node => {
      node.addEventListener('mouseenter', (e) => {
        const msg = (node as HTMLElement).getAttribute('data-tooltip');
        if (msg) {
          tooltip.textContent = msg;
          tooltip.style.opacity = '1';
        }
      });

      node.addEventListener('mousemove', (e: any) => {
        tooltip.style.left = `${e.clientX + 15}px`;
        tooltip.style.top = `${e.clientY + 15}px`;
      });

      node.addEventListener('mouseleave', () => {
        tooltip.style.opacity = '0';
      });
    });

    // Initial draw
    setTimeout(drawConnections, 100);
    window.addEventListener('resize', drawConnections);
    
    document.addEventListener('astro:page-load', drawConnections);
    
    // Also run immediately
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          drawConnections();
        }
      });
    }, { threshold: 0.1 });
    observer.observe(svg);
  }

  // Run on load and on Astro view transitions
  document.addEventListener('DOMContentLoaded', initPipeline);
  document.addEventListener('astro:page-load', initPipeline);
  
  if (document.readyState === 'interactive' || document.readyState === 'complete') {
    initPipeline();
  }
</script>
