  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden bg-surface/95 backdrop-blur-sm items-center justify-center p-4 md:p-12 cursor-zoom-out">
    <img id="lightbox-img" src="" alt="Full size infographic" class="max-w-full max-h-full rounded-sm shadow-2xl object-contain" />
  </div>

  <script>
    function setupLightbox() {
      const figure = document.getElementById('thesis-figure');
      const lightbox = document.getElementById('lightbox');
      const lightboxImg = document.getElementById('lightbox-img');

      if (figure && lightbox && lightboxImg) {
        figure.onclick = () => {
          lightboxImg.setAttribute('src', figure.getAttribute('src') || '');
          lightbox.classList.remove('hidden');
          lightbox.classList.add('flex');
        };
        lightbox.onclick = () => {
          lightbox.classList.remove('flex');
          lightbox.classList.add('hidden');
        };
      }
    }
    
    document.addEventListener('astro:page-load', setupLightbox);
    setupLightbox();
  </script>
