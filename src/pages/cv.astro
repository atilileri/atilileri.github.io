    <div class="h-px w-full bg-on-surface/10 mb-24"></div>

    <!-- Skills Section -->
    <section class="grid grid-cols-12 gap-8 mb-32">
      <div class="col-span-12 md:col-span-4 mb-8 md:mb-0">
        <h2 class="text-[2rem] font-black tracking-tighter uppercase mb-8">
          Technical Stack
        </h2>
      </div>

      <div
        class="col-span-12 md:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-12 text-sm"
      >
        <div>
          <h4
            class="text-[0.75rem] uppercase tracking-[0.2em] font-black mb-6 text-primary"
          >
            Core Engineering
          </h4>
          <ul class="flex flex-col gap-3">
            <li
              class="flex justify-between items-center font-medium border-b border-on-surface/5 pb-2 hover:text-primary transition-colors"
            >
              <span>Safety Critical Systems</span>
              <span class="text-[0.75rem] font-black opacity-30">01</span>
            </li>
            <li
