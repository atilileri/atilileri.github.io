---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const uniqueTags = [
    ...new Set(allPosts.map((post) => post.data.tags).flat()),
  ];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts
      .filter((post) => post.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};
---

<BaseLayout
  title={`Posts tagged with "${tag}"`}
  description={`Browse all engineering logs and field notes tagged with ${tag}.`}
  currentPath="/blog/"
>
  <div class="max-w-5xl mx-auto px-12 py-12">
    <header class="mb-16">
      <div
        class="flex items-center gap-2 text-[var(--color-primary-container)] mb-4 font-mono text-xs font-bold uppercase tracking-widest"
      >
        <a href="/blog/" class="hover:underline">Blog</a>
        <span>/</span>
        <span>Tag</span>
      </div>
      <h1
        class="font-[Space_Grotesk] text-7xl font-bold tracking-tighter text-[var(--color-on-surface)] leading-[0.9] mb-4"
      >
        TAG: <br />
        <span class="text-[var(--color-primary-container)] italic"
          >{tag.toLocaleUpperCase('tr-TR')}</span
        >
      </h1>
      <p class="text-[var(--color-on-surface-variant)] max-w-xl font-light">
        Showing {posts.length}
        {posts.length === 1 ? "article" : "articles"} matching this category.
      </p>
    </header>

    <section class="space-y-12">
      {
        posts.map((post) => (
          <article class="group flex flex-col md:flex-row gap-8 items-start pb-12 border-b border-[var(--color-outline-variant)]/10">
            <div class="w-full md:w-1/3 flex-shrink-0">
              <a href={`/blog/${post.id}/`} class="block group/image">
                <div class="aspect-video overflow-hidden rounded-lg ghost-border">
                  <img
                    src={post.data.heroImage || "/images/blog-placeholder.jpg"}
                    alt={post.data.title}
                    class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 transform group-hover:scale-105"
                  />
                </div>
              </a>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="bg-[var(--color-primary-container)]/10 text-[var(--color-primary-container)] text-[10px] font-bold px-2 py-1 uppercase tracking-widest">
                  {tag.toLocaleUpperCase(post.data.lang === 'tr' ? 'tr-TR' : 'en-US')}
                </span>
                <span class="text-[10px] text-[var(--color-outline)] font-mono">
                  {formatDate(post.data.pubDate)}
                </span>
              </div>
              <a href={`/blog/${post.id}/`} class="block">
                <h2 class="font-[Space_Grotesk] text-2xl font-bold tracking-tight group-hover:text-[var(--color-primary-container)] transition-colors mb-3">
                  {post.data.title}
                </h2>
              </a>
              <p class="text-[var(--color-on-surface-variant)] text-sm leading-relaxed mb-4">
                {post.data.description}
              </p>
              <a
                href={`/blog/${post.id}/`}
                class="text-[var(--color-primary-container)] text-xs font-bold uppercase tracking-widest flex items-center gap-1 group-hover:gap-3 transition-all"
              >
                READ ARTICLE
                <span class="material-symbols-outlined text-sm">
                  arrow_forward
                </span>
              </a>
            </div>
          </article>
        ))
      }
    </section>

    <div class="mt-16">
      <a
        href="/blog/"
        class="inline-flex items-center gap-2 text-[var(--color-outline)] font-bold tracking-widest text-xs uppercase hover:text-[var(--color-on-surface)] transition-colors"
      >
        <span class="material-symbols-outlined text-sm">arrow_back</span>
        Back to all posts
      </a>
    </div>
  </div>
</BaseLayout>
