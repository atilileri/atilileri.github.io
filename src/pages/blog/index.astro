---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Placeholder blog posts — will be replaced by content collections
const posts = [
  {
    slug: "cost-of-latency",
    title: "The Cost of 1ms: Latency in Lithography Control Systems",
    excerpt: "Exploring the non-linear cost of latency in high-precision EUV manufacturing and why nanosecond-level optimization matters.",
    date: "2024-10-08",
    category: "Deep Dive",
    readTime: "12 min read",
    image: "/images/blog-1.jpg",
  },
  {
    slug: "flow-state-programming",
    title: "Harnessing Flow State: A Programmer's Guide to Deep Work",
    excerpt: "Borrowing techniques from extreme sports to achieve consistent flow states in software engineering.",
    date: "2024-09-22",
    category: "Productivity",
    readTime: "8 min read",
    image: "/images/blog-2.jpg",
  },
  {
    slug: "rust-embedded-systems",
    title: "Rust for Embedded: Memory Safety When It Matters Most",
    excerpt: "How Rust's ownership model prevents entire categories of bugs in mission-critical embedded systems.",
    date: "2024-09-05",
    category: "Technical",
    readTime: "15 min read",
    image: "/images/blog-3.jpg",
  },
  {
    slug: "kitesurfing-decision-making",
    title: "What 20-knot Wind Teaches About Engineering Decisions",
    excerpt: "Drawing parallels between high-speed kite maneuvers and critical system design choices under pressure.",
    date: "2024-08-18",
    category: "Essay",
    readTime: "6 min read",
    image: "/images/blog-4.jpg",
  },
];
---

<BaseLayout
  title="Blog"
  description="Engineering perspectives, deep dives, and field notes from the intersection of lithography and extreme sports."
  currentPath="/blog/"
>
  <div class="max-w-5xl mx-auto px-12 py-12">
    <!-- Hero -->
    <header class="mb-16">
      <h1
        class="font-[Space_Grotesk] text-7xl font-bold tracking-tighter text-[var(--color-on-surface)] leading-[0.9] mb-4"
      >
        ENGINEERING <br />
        <span class="text-[var(--color-primary-container)] italic"
          >PERSPECTIVES</span
        >
      </h1>
      <p class="text-[var(--color-on-surface-variant)] max-w-xl font-light">
        Deep dives, system breakdowns, and field notes from the intersection of
        software architecture and kinetic performance.
      </p>
    </header>

    <!-- Article List -->
    <section class="space-y-12">
      {
        posts.map((post) => (
          <article class="group flex flex-col md:flex-row gap-8 items-start pb-12 border-b border-[var(--color-outline-variant)]/10">
            <div class="w-full md:w-1/3 flex-shrink-0">
              <div class="aspect-video overflow-hidden rounded-lg ghost-border">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 transform group-hover:scale-105"
                />
              </div>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="bg-[var(--color-primary-container)]/10 text-[var(--color-primary-container)] text-[10px] font-bold px-2 py-1 uppercase tracking-widest">
                  {post.category}
                </span>
                <span class="text-[10px] text-[var(--color-outline)] font-mono">
                  {post.date}
                </span>
                <span class="text-[10px] text-[var(--color-outline)] font-mono">
                  {post.readTime}
                </span>
              </div>
              <a
                href={`/blog/${post.slug}/`}
                class="block"
              >
                <h2 class="font-[Space_Grotesk] text-2xl font-bold tracking-tight group-hover:text-[var(--color-primary-container)] transition-colors mb-3">
                  {post.title}
                </h2>
              </a>
              <p class="text-[var(--color-on-surface-variant)] text-sm leading-relaxed mb-4">
                {post.excerpt}
              </p>
              <a
                href={`/blog/${post.slug}/`}
                class="text-[var(--color-primary-container)] text-xs font-bold uppercase tracking-widest flex items-center gap-1 group-hover:gap-3 transition-all"
              >
                READ ARTICLE
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </a>
            </div>
          </article>
        ))
      }
    </section>

    <!-- Newsletter Section -->
    <section class="mt-24 glass-card ghost-border rounded-xl p-12 text-center">
      <span
        class="material-symbols-outlined text-[var(--color-primary-container)] text-3xl mb-4 block"
        >mail</span
      >
      <h3 class="font-[Space_Grotesk] text-2xl font-bold mb-3">
        SUBSCRIBE TO THE ENGINEERING LOG
      </h3>
      <p
        class="text-[var(--color-on-surface-variant)] text-sm max-w-md mx-auto mb-8"
      >
        Monthly dispatches on system architecture, precision engineering, and
        what wind teaches about code.
      </p>
      <div class="flex max-w-md mx-auto">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 bg-[var(--color-surface-container-low)] border border-[var(--color-outline-variant)]/20 rounded-l-lg px-4 py-3 text-sm focus:ring-1 focus:ring-[var(--color-primary-container)] focus:outline-none"
        />
        <button
          class="kinetic-gradient px-6 py-3 rounded-r-lg text-[var(--color-on-primary-fixed)] font-bold text-sm"
        >
          SUBSCRIBE
        </button>
      </div>
    </section>
  </div>
</BaseLayout>
