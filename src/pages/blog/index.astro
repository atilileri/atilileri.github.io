---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};
---

<BaseLayout
  title="Blog"
  description="Engineering perspectives, deep dives, and field notes from the intersection of lithography and extreme sports."
  currentPath="/blog/"
>
  <div class="max-w-5xl mx-auto px-12 py-12">
    <!-- Hero -->
    <header class="mb-16 flex flex-col md:flex-row md:justify-between md:items-end gap-6 border-b border-[var(--color-outline-variant)]/10 pb-8">
      <div>
        <h1
          class="font-[Space_Grotesk] text-7xl font-bold tracking-tighter text-[var(--color-on-surface)] leading-[0.9] mb-4"
        >
          UNCOMMON
          <span class="text-[var(--color-primary-container)] italic">SENSE</span>
        </h1>
        <p class="text-[var(--color-on-surface-variant)] max-w-xl font-light">
          Distilling human research and AI-powered insights to uncover the
          counter-intuitive truths of a life in motion.
        </p>
      </div>

      <!-- Language Toggle -->
      <div class="flex bg-[var(--color-surface-container-low)] rounded-lg p-1 border border-[var(--color-outline-variant)]/20 w-fit">
        <button id="lang-toggle-en" class="px-4 py-2 rounded-md text-sm font-bold tracking-widest transition-all bg-[var(--color-primary-container)] text-[var(--color-on-primary-fixed)]">EN</button>
        <button id="lang-toggle-tr" class="px-4 py-2 rounded-md text-sm font-bold tracking-widest transition-all text-[var(--color-on-surface-variant)] hover:text-[var(--color-on-surface)]">TR</button>
      </div>
    </header>

    <section class="space-y-12">
      {
        posts.map((post) => (
          <article 
            class="blog-post-card group flex flex-col md:flex-row gap-8 items-start pb-12 border-b border-[var(--color-outline-variant)]/10"
            data-lang={post.data.lang}
            data-translation-id={post.data.translationId || ""}
          >
            <div class="w-full md:w-1/3 flex-shrink-0">
              <div class="aspect-video overflow-hidden rounded-lg ghost-border">
                <img
                  src={post.data.heroImage || "/images/blog-placeholder.jpg"}
                  alt={post.data.title}
                  class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 transform group-hover:scale-105"
                />
              </div>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <a
                  href={`/blog/tag/${post.data.tags[0] || "General"}/`}
                  class="bg-[var(--color-primary-container)]/10 text-[var(--color-primary-container)] hover:bg-[var(--color-primary-container)]/20 text-[10px] font-bold px-2 py-1 uppercase tracking-widest transition-colors"
                >
                  {post.data.tags[0] || "General"}
                </a>
                <span class="text-[10px] text-[var(--color-outline)] font-mono">
                  {formatDate(post.data.pubDate)}
                </span>
              </div>
              <a href={`/blog/${post.id}/`} class="block">
                <h2 class="font-[Space_Grotesk] text-2xl font-bold tracking-tight group-hover:text-[var(--color-primary-container)] transition-colors mb-3">
                  {post.data.title}
                </h2>
              </a>
              <p class="text-[var(--color-on-surface-variant)] text-sm leading-relaxed mb-4">
                {post.data.description}
              </p>
              <a
                href={`/blog/${post.id}/`}
                class="text-[var(--color-primary-container)] text-xs font-bold uppercase tracking-widest flex items-center gap-1 group-hover:gap-3 transition-all"
              >
                READ ARTICLE
                <span class="material-symbols-outlined text-sm">
                  arrow_forward
                </span>
              </a>
            </div>
          </article>
        ))
      }
    </section>

    <!-- Newsletter Section -->
    <section class="mt-24 glass-card ghost-border rounded-xl p-12 text-center">
      <span
        class="material-symbols-outlined text-[var(--color-primary-container)] text-3xl mb-4 block"
        >mail</span
      >
      <h3 class="font-[Space_Grotesk] text-2xl font-bold mb-3">
        SUBSCRIBE TO THE ENGINEERING LOG
      </h3>
      <p
        class="text-[var(--color-on-surface-variant)] text-sm max-w-md mx-auto mb-8"
      >
        Monthly dispatches on system architecture, precision engineering, and
        what wind teaches about code.
      </p>
      <div class="flex max-w-md mx-auto">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 bg-[var(--color-surface-container-low)] border border-[var(--color-outline-variant)]/20 rounded-l-lg px-4 py-3 text-sm focus:ring-1 focus:ring-[var(--color-primary-container)] focus:outline-none"
        />
        <button
          class="kinetic-gradient px-6 py-3 rounded-r-lg text-[var(--color-on-primary-fixed)] font-bold text-sm"
        >
          SUBSCRIBE
        </button>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  function setupLangToggle() {
    const btnEn = document.getElementById('lang-toggle-en');
    const btnTr = document.getElementById('lang-toggle-tr');
    const articles = document.querySelectorAll('.blog-post-card');

    if (!btnEn || !btnTr || articles.length === 0) return;

    // Use Astro view transitions safe initialization
    let currentLang = localStorage.getItem('blog-lang') || 'en';

    const renderToggle = () => {
      if (currentLang === 'en') {
        btnEn.className = 'px-4 py-2 rounded-md text-sm font-bold tracking-widest transition-all bg-[var(--color-primary-container)] text-[var(--color-on-primary-fixed)]';
        btnTr.className = 'px-4 py-2 rounded-md text-sm font-bold tracking-widest transition-all text-[var(--color-on-surface-variant)] hover:text-[var(--color-on-surface)]';
      } else {
        btnTr.className = 'px-4 py-2 rounded-md text-sm font-bold tracking-widest transition-all bg-[var(--color-primary-container)] text-[var(--color-on-primary-fixed)]';
        btnEn.className = 'px-4 py-2 rounded-md text-sm font-bold tracking-widest transition-all text-[var(--color-on-surface-variant)] hover:text-[var(--color-on-surface)]';
      }
    };

    const filterArticles = () => {
      const translationGroups: Record<string, Element[]> = {};
      
      articles.forEach(article => {
        const tId = article.getAttribute('data-translation-id');
        if (tId) {
          if (!translationGroups[tId]) translationGroups[tId] = [];
          translationGroups[tId].push(article);
        }
      });

      articles.forEach(article => {
        const lang = article.getAttribute('data-lang');
        const tId = article.getAttribute('data-translation-id');
        let show = false;

        if (lang === currentLang) {
          show = true;
        } else if (tId && translationGroups[tId].length === 1) {
          show = true; // Fallback to other lang if no translation
        } else if (!tId) {
          show = true; // Fallback to other lang if no translation
        }

        if (show) {
          (article as HTMLElement).style.display = 'flex';
        } else {
          (article as HTMLElement).style.display = 'none';
        }
      });
    };

    const setLang = (lang: string) => {
      currentLang = lang;
      localStorage.setItem('blog-lang', lang);
      renderToggle();
      filterArticles();
    };

    btnEn.addEventListener('click', () => setLang('en'));
    btnTr.addEventListener('click', () => setLang('tr'));

    renderToggle();
    filterArticles();
  }

  // Handle both initial load and Astro page transitions
  document.addEventListener('DOMContentLoaded', setupLangToggle);
  document.addEventListener('astro:page-load', setupLangToggle);
  
  // Also run immediately in case it's loaded late
  if (document.readyState === 'interactive' || document.readyState === 'complete') {
    setupLangToggle();
  }
</script>
