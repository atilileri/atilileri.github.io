---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Now" currentPath="/now">
  <div class="px-6 md:px-12 max-w-[1440px] mx-auto overflow-hidden">
    <!-- Hero Section: Swiss Typography Focal Point -->
    <header class="mb-32 grid grid-cols-12 gap-8 items-end">
      <div class="col-span-12 md:col-span-8">
        <span class="text-[0.75rem] font-bold uppercase tracking-[0.2em] text-primary mb-6 block">STATUS REPORT / CURRENT PHASE</span>
        <h1 class="text-[clamp(3.5rem,10vw,8rem)] leading-[0.9] font-black tracking-tighter uppercase mb-8">
          ACTIVE<br />EVOLUTION
        </h1>
      </div>
      <div class="col-span-12 md:col-span-4 flex flex-col items-end pb-4 border-l-0 md:border-l border-on-surface/10 md:pl-12">
        <p class="text-on-surface-variant font-body text-lg leading-relaxed mb-6 text-right max-w-xs">
          Real-time updates on professional milestones, athletic pursuits, and the continuous process of linguistic acquisition.
        </p>
        <div class="w-16 h-1 bg-primary"></div>
      </div>
    </header>

    <!-- The Timeline / Typographic List -->
    <section class="relative grid grid-cols-1 md:grid-cols-12 gap-0">
      <!-- Vertical Line -->
      <div class="hidden md:block absolute left-[50%] top-0 bottom-0 w-[1px] bg-on-surface/10 translate-x-[-0.5px]"></div>

      <!-- Timeline Entry 1: NBA / Sports -->
      <div class="md:col-span-5 mb-24 md:text-right relative">
        <div class="hidden md:block absolute right-[-24px] top-4 w-4 h-4 bg-primary rounded-full translate-x-[50%] z-10 ring-4 ring-background"></div>
        <div class="flex md:flex-row-reverse items-center gap-4 mb-4">
          <span class="material-symbols-outlined text-primary text-4xl">sports_basketball</span>
          <span class="text-[0.75rem] font-bold uppercase tracking-[0.1em] text-on-surface/40">MARCH 2024 — PRESENT</span>
        </div>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6 uppercase leading-tight">CHASING THE<br />HARDWOOD</h2>
        <div class="p-8 bg-surface-container-low relative">
          <p class="text-lg leading-relaxed text-on-surface-variant font-medium text-left md:text-right">
            Deep dive into NBA advanced analytics and technical scouting. Analyzing pick-and-roll efficiencies and defensive rotations for the current season.
          </p>
        </div>
      </div>
      <div class="md:col-span-7 hidden md:block"></div>

      <!-- Timeline Entry 2: Dutch Learning -->
      <div class="md:col-span-7 hidden md:block"></div>
      <div class="md:col-span-5 mb-24 relative pt-12">
        <div class="hidden md:block absolute left-[-24px] top-16 w-4 h-4 bg-tertiary rounded-full translate-x-[-50%] z-10 ring-4 ring-background"></div>
        <div class="flex items-center gap-4 mb-4">
          <span class="material-symbols-outlined text-tertiary text-4xl">language</span>
          <span class="text-[0.75rem] font-bold uppercase tracking-[0.1em] text-on-surface/40">FEBRUARY 2024 — ONGOING</span>
        </div>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6 uppercase leading-tight">NEDERLANDS<br />B1 LEVEL</h2>
        <div class="p-8 bg-surface-container-low border-l-4 md:border-l-0 md:border-r-4 border-tertiary">
          <p class="text-lg leading-relaxed text-on-surface-variant font-medium">
            Mastering the grammar structures of "de" and "het." Focusing on conversational fluency and technical professional vocabulary for the Dutch market.
          </p>
        </div>
      </div>

      <!-- Timeline Entry 3: Volunteering -->
      <div class="md:col-span-5 mb-24 md:text-right relative pt-12">
        <div class="hidden md:block absolute right-[-24px] top-16 w-4 h-4 bg-primary-container rounded-full translate-x-[50%] z-10 ring-4 ring-background"></div>
        <div class="flex md:flex-row-reverse items-center gap-4 mb-4">
          <span class="material-symbols-outlined text-primary-container text-4xl">volunteer_activism</span>
          <span class="text-[0.75rem] font-bold uppercase tracking-[0.1em] text-on-surface/40">JANUARY 2024 — IMPACT</span>
        </div>
        <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6 uppercase leading-tight">URBAN<br />RENEWAL</h2>
        <div class="p-8 bg-surface-container-low">
          <p class="text-lg leading-relaxed text-on-surface-variant font-medium text-left md:text-right">
            Weekly engagement with local community centers helping digitize archival neighborhood history. Building sustainable digital bridges for the elderly.
          </p>
        </div>
      </div>
      <div class="md:col-span-7"></div>
    </section>
  </div>

  <!-- Geometric Signature Section -->
  <section class="mt-40 bg-[#1b1b1b] p-12 md:p-24 relative overflow-hidden">
    <!-- Background Shape -->
    <div
      class="absolute right-0 top-0 w-2/3 h-full opacity-20 pointer-events-none"
      style="background: conic-gradient(from 180deg at 50% 50%, #00327d 0deg, #651f00 360deg); filter: blur(100px);"
    ></div>
    <div class="relative z-10 max-w-3xl mx-auto md:mx-0">
      <span class="text-[var(--color-primary-container)] font-bold tracking-[0.3em] text-xs uppercase mb-8 block">THE ARCHITECTURAL CORE</span>
      <h3 class="text-[#f9f9f9] text-4xl md:text-7xl font-black tracking-tighter mb-12 uppercase leading-[0.9]">
        EVERY UPDATE IS A <span class="text-[var(--color-primary)]">STRUCTURE</span> IN PROGRESS.
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-6 bg-white/5 backdrop-blur-md">
          <p class="text-[rgba(249,249,249,0.4)] text-[0.6rem] uppercase tracking-widest mb-2">NBA Games</p>
          <p class="text-[#f9f9f9] text-3xl font-black">82</p>
        </div>
        <div class="p-6 bg-white/5 backdrop-blur-md">
          <p class="text-[rgba(249,249,249,0.4)] text-[0.6rem] uppercase tracking-widest mb-2">Vocabulary</p>
          <p class="text-[#f9f9f9] text-3xl font-black">2.4K</p>
        </div>
        <div class="p-6 bg-white/5 backdrop-blur-md">
          <p class="text-[rgba(249,249,249,0.4)] text-[0.6rem] uppercase tracking-widest mb-2">Hours Contributed</p>
          <p class="text-[#f9f9f9] text-3xl font-black">120</p>
        </div>
        <div class="p-6 bg-white/5 backdrop-blur-md">
          <p class="text-[rgba(249,249,249,0.4)] text-[0.6rem] uppercase tracking-widest mb-2">Systems Built</p>
          <p class="text-[#f9f9f9] text-3xl font-black">14</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
