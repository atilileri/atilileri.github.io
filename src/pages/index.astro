---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home" currentPath="/">
  <!-- Hero Section: Swiss Modernist Layout -->
  <section class="relative min-h-[max(calc(100vh-160px),700px)] flex items-center px-12 max-w-[1440px] mx-auto overflow-hidden">
    <!-- Background Geometric Soul -->
    <div class="absolute right-[-10%] top-[10%] w-[600px] h-[600px] rounded-full geometric-accent opacity-90 mix-blend-multiply filter blur-[2px] dark:opacity-30"></div>
    <div class="relative z-10 w-full grid grid-cols-12 gap-8 items-end">
      <div class="col-span-12 lg:col-span-8">
        <span class="label-md text-[0.75rem] uppercase tracking-[0.2em] text-primary font-bold mb-6 block">01 / MANIFESTO</span>
        <h1 class="text-[5rem] md:text-[8rem] lg:text-[10rem] font-black leading-[0.85] tracking-[-0.05em] text-on-background mb-8">
          LESS IS<br />MORE.
        </h1>
        <p class="max-w-md text-lg leading-relaxed text-on-surface-variant font-medium">
          A radical pursuit of objectivity and mathematical grid logic. We strip
          away the unnecessary to reveal the architectural soul of digital
          experiences.
        </p>
      </div>
      <!-- B&W Portrait with Sharp Edge -->
      <div class="col-span-12 lg:col-span-4 flex justify-end relative h-[500px]">
        <div class="w-full h-full bg-surface-container-highest relative overflow-hidden group">
          <img
            alt="Professional portrait"
            class="w-full h-full object-cover grayscale contrast-125 brightness-90"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCSHeegDGzzwqWlVo7xzxdySqkQ3JqU63lfN2C4SAaXLGeDXHvv_r2eCSM23rkq6ERhalMvQE187zKQJOH_1HPfdTmPi66VmTT-3m9Sysj9LZWLSAzaOH-3rnQQlrOBF0MQ5KMXY_t_Zn_FVqETU86n-azhrvIkpDf6OhE2XjwiWrBM0xLwCGp8qdl2fPFCIgdtTJ-ufJ_m0-6ozEVipaGTMDb05l71g9tzGkR4Y9z86OZbrx7YvF98eCkJjqgezMFemsBTm-b-WZ3P"
          />
          <!-- Technical Overlay -->
          <div class="absolute bottom-4 left-4 bg-on-background text-surface text-[0.65rem] px-3 py-1 tracking-widest uppercase">
            FOUNDER / ARCHITECT
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Bento Philosophy Grid -->
  <section class="bg-surface-container-low py-32 px-12 mt-12 w-full">
    <div class="max-w-[1440px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-1">
        <!-- Grid Item 1 -->
        <div class="bg-surface p-12 flex flex-col justify-between h-[400px]">
          <span class="text-xs tracking-[0.3em] font-bold text-outline">PRECISION</span>
          <div>
            <h3 class="text-3xl font-bold mb-4 tracking-tighter">0.01mm Tolerance</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              Every pixel is accounted for in a mathematical grid that ensures perfect harmony across all viewport scales.
            </p>
          </div>
        </div>
        <!-- Grid Item 2 -->
        <div class="bg-primary p-12 flex flex-col justify-between h-[400px] text-on-primary">
          <span class="text-xs tracking-[0.3em] font-bold opacity-60">SYSTEMS</span>
          <div>
            <h3 class="text-3xl font-bold mb-4 tracking-tighter">Modular Core</h3>
            <p class="text-sm opacity-80 leading-relaxed">
              Built on a foundation of interchangeable modules, allowing for rapid evolution without sacrificing structural integrity.
            </p>
          </div>
        </div>
        <!-- Grid Item 3 -->
        <div class="bg-surface p-12 flex flex-col justify-between h-[400px]">
          <span class="text-xs tracking-[0.3em] font-bold text-outline">AESTHETIC</span>
          <div>
            <h3 class="text-3xl font-bold mb-4 tracking-tighter">Objective Clarity</h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              We favor functional beauty over decorative clutter. The content dictates the form, always.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Signature Component: The Geometric Hero -->
  <section class="py-32 px-12 max-w-[1440px] mx-auto overflow-hidden relative">
    <div class="grid grid-cols-12 gap-12 items-center">
      <div class="col-span-12 lg:col-span-5 relative z-20">
        <h2 class="text-5xl font-black tracking-tighter leading-none mb-12 uppercase">The Digital<br />Lithograph</h2>
        <div class="space-y-8">
          <div class="border-l-4 border-primary pl-6">
            <h4 class="font-bold uppercase tracking-widest text-xs mb-2">Typography as Structure</h4>
            <p class="text-on-surface-variant">Type is not just for reading; it is the primary structural element of our design language.</p>
          </div>
          <div class="border-l-4 border-surface-variant pl-6">
            <h4 class="font-bold uppercase tracking-widest text-xs mb-2">Intentional Asymmetry</h4>
            <p class="text-on-surface-variant">We break the grid to create focal tension, guiding the eye through a curated narrative path.</p>
          </div>
        </div>
      </div>
      <div class="col-span-12 lg:col-span-7 relative">
        <!-- Abstract Geometric Artifact -->
        <div class="aspect-square w-full relative flex items-center justify-center">
          <div class="absolute inset-0 bg-surface-variant opacity-50 transform rotate-45 scale-75"></div>
          <div class="absolute inset-0 bg-primary opacity-10 transform -rotate-12 translate-x-12 translate-y-12"></div>
          <div class="z-20 p-12 border border-on-surface/10 backdrop-blur-xl">
            <img
              alt="Abstract geometry"
              class="w-full grayscale contrast-150 mix-blend-luminosity dark:mix-blend-screen opacity-90"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuBIgEePWUIGs6LiG-huSo6osGkLBdUyJsBdXsuhXjV6MhPM1AOvAC_wPHH6nqVSPiH9YKon0NdlpSrHPeTlIRbI0l76gQZgYsKvZSE1uHGvRhZoYQ6hZIhX3OwOJzkIQJzPJBTYYasRDCdpyWhGokoDDcuGcxfeC8L-aQdK3DFn_MDVXx8EAAEsrs8gxepCzJqofNi7FZX17bs8D_DvECqwG-2qbjGdiewLwRgd0wABWRHk3EFOPH-XVCuJaiLV_uVY49lxcwYyuIyI"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
