---
// Prototype (issue #7) — Spectacle capability showcase, published at
// /proto/spectacle/ as a shareable demo. Explores Spectacle as the
// presentation framework for the map in issue #4.
// The whole deck is a single client:only React island — Spectacle owns the
// full viewport and manages its own routing/keyboard nav, so SSR is pointless.
import SpectacleDeck from "../../components/prototype/SpectacleDeck.jsx";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Spectacle showcase — prototype</title>
    <meta name="robots" content="noindex" />
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: #05060a;
      }
    </style>
  </head>
  <body>
    <SpectacleDeck client:only="react" />
  </body>
</html>
