---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Uses" currentPath="/uses">
  <!-- Hero Section -->
  <header class="mb-24 flex flex-col items-start gap-6 max-w-[1440px] px-12 mx-auto">
    <span class="text-[0.75rem] uppercase tracking-[0.2em] font-bold text-primary">Workspace & Tech Stack</span>
    <h1 class="text-[3.5rem] md:text-[5rem] font-black leading-[0.95] tracking-tighter max-w-4xl uppercase">
      Tools for <br /> <span class="text-primary">Precision</span> Output.
    </h1>
    <p class="text-on-surface-variant text-lg max-w-2xl mt-4 leading-relaxed">
      A curated collection of the hardware and software that powers my creative workflow—from architectural code to alpine adventures.
    </p>
  </header>

  <!-- Bento Grid -->
  <section class="max-w-[1440px] px-12 mx-auto">
    <div class="grid grid-cols-12 gap-1 bg-surface-container-highest p-1 rounded-sm overflow-hidden">
      <!-- Dev Stack (Large Span) -->
      <div class="col-span-12 md:col-span-8 bg-surface p-12 flex flex-col justify-between min-h-[400px]">
        <div>
          <span class="text-[0.65rem] uppercase tracking-widest font-semibold opacity-50 mb-8 block">Software Ecosystem</span>
          <h2 class="text-4xl font-bold tracking-tighter mb-12">THE CORE ARCHITECTURE</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
            <div class="flex flex-col gap-2">
              <span class="material-symbols-outlined text-primary text-3xl">terminal</span>
              <span class="font-bold text-sm tracking-tight">VS CODE / NEOVIM</span>
              <span class="text-[0.7rem] uppercase tracking-tighter opacity-40">Editor</span>
            </div>
            <div class="flex flex-col gap-2">
              <span class="material-symbols-outlined text-primary text-3xl">grid_view</span>
              <span class="font-bold text-sm tracking-tight">DOCKER / K8S</span>
              <span class="text-[0.7rem] uppercase tracking-tighter opacity-40">Orchestration</span>
            </div>
            <div class="flex flex-col gap-2">
              <span class="material-symbols-outlined text-primary text-3xl">database</span>
              <span class="font-bold text-sm tracking-tight">POSTGRESQL</span>
              <span class="text-[0.7rem] uppercase tracking-tighter opacity-40">Persistence</span>
            </div>
            <div class="flex flex-col gap-2">
              <span class="material-symbols-outlined text-primary text-3xl">hub</span>
              <span class="font-bold text-sm tracking-tight">RUST / GO</span>
              <span class="text-[0.7rem] uppercase tracking-tighter opacity-40">Languages</span>
            </div>
          </div>
        </div>
        <div class="mt-12 flex items-center gap-4 text-xs font-bold border-t border-on-surface/5 pt-6">
          <span class="bg-primary/5 text-primary px-3 py-1">PRODUCTION READY</span>
          <span class="opacity-30">LATEST REV: 2024.04</span>
        </div>
      </div>

      <!-- Burton Board Image -->
      <div class="col-span-12 md:col-span-4 bg-surface relative group overflow-hidden h-[400px]">
        <img
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuAGFB-LNdtDlHqMpC6CjYag5Zb1PZCdQhDVNsdY09XMvbgaJm6k260iQRVJgKKg6BDF9vk70oZ49bO6bj3Ui6wAPFIoz1c9fEE4BWYMIZOOCMQpGY6SB6Sk0PaeWO2GoL5iMvpgSK98-eLnguI8284HYPB399MIO0mseJwyY6ygUj3hgVgbfxrq_vj535R5IYMx-Wzw1wc5xhcfX1n34BhhHfkEPk-Mrj45xZ8tPF1B6mDYaRwKqeCppGuJYuWFXDOsaLv66T64x3Ep"
        />
        <div class="absolute bottom-0 left-0 p-8 bg-surface w-full">
          <span class="text-xs font-black tracking-widest uppercase">BURTON CUSTOM CAMBER</span>
          <p class="text-[0.7rem] opacity-50 mt-1">THE ALPINE STANDARD</p>
        </div>
      </div>

      <!-- Hardware Spec -->
      <div class="col-span-12 md:col-span-4 bg-on-surface text-surface p-12 flex flex-col justify-between h-[450px]">
        <div>
          <span class="material-symbols-outlined text-surface/30 text-5xl mb-6">laptop_mac</span>
          <h3 class="text-3xl font-black leading-none mb-4">MBP M3 MAX<br />64GB RAM</h3>
          <p class="text-surface/60 text-sm leading-relaxed">
            The heavy-lifter. Configured for local LLM inferencing and multi-container development environments.
          </p>
        </div>
        <div class="text-[0.65rem] border-l border-surface/20 pl-4 tracking-[0.1em]">
          SERIAL: SYS-ARC-0012<br />
          STATUS: OPERATIONAL
        </div>
      </div>

      <!-- Kitesurf Gear -->
      <div class="col-span-12 md:col-span-4 bg-surface p-12 flex flex-col h-[450px]">
        <div class="flex-grow flex flex-col h-full">
          <span class="text-primary text-[0.7rem] font-bold uppercase tracking-widest mb-4 block">Aero Dynamics</span>
          <h3 class="text-3xl font-bold tracking-tighter mb-6 uppercase">North Reach 12M</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed mb-8 flex-grow">
            Precision-engineered kitesurfing equipment for high-wind stability and effortless technical maneuvers.
          </p>
          <div class="grid grid-cols-2 gap-4 mt-auto">
            <div class="border border-on-surface/10 p-4">
              <span class="block text-[0.6rem] opacity-40 uppercase">Control</span>
              <span class="text-sm font-bold">Navigator Bar</span>
            </div>
            <div class="border border-on-surface/10 p-4">
              <span class="block text-[0.6rem] opacity-40 uppercase">Hull</span>
              <span class="text-sm font-bold">Atmos Carbon</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Secondary Image -->
      <div class="col-span-12 md:col-span-4 bg-surface relative overflow-hidden h-[450px]">
        <img
          class="w-full h-full object-cover"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDwriDZTN0i2GBy3afagI-WG_Q5nlLTdKHGyPXGN7P_aBM8s_mgEeTjrZtJQ1qFCivbTWyVjUnaJaF_7jYJME05XkERtvW9c6SpmsiA2bfYchIyyATWPYXB0XBJYhnrANQ4VgslXRWTImsj-cXpq_64AiDAwPHSLWLbbyrzEgsoPuCUix6ENnfy6Xj4Cy1B1D-xkn8u1W-4TyJWkuzx_AYT5tzMVMVMGAD1bvoARF742WlYAiFf-7CJSYmAHOFq_3Uq41jIXCR_wMu8"
        />
        <div class="absolute inset-0 bg-primary/10 mix-blend-multiply border border-on-surface/5"></div>
      </div>

      <!-- Daily Drivers (Bento Bottom) -->
      <div class="col-span-12 bg-surface p-12">
        <div class="flex flex-col md:flex-row justify-between items-end gap-12">
          <div class="flex flex-col gap-2">
            <h4 class="text-xl font-bold uppercase tracking-tighter">The Essentials</h4>
            <div class="flex flex-wrap gap-8 mt-4">
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">headphones</span>
                <span class="text-xs font-bold uppercase">Sony WH-1000XM5</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">keyboard</span>
                <span class="text-xs font-bold uppercase">HHKB Hybrid Type-S</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">watch</span>
                <span class="text-xs font-bold uppercase">Garmin Fenix 7X</span>
              </div>
            </div>
          </div>
          <div class="text-right">
            <span class="text-[3rem] font-black opacity-5 tracking-tighter uppercase">Est. 2024</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Signature Component: Geometric Hero Break -->
  <section class="mt-24 py-32 bg-on-background relative overflow-hidden flex items-center justify-center">
    <!-- 3D Geometric Shape Simulation -->
    <div class="absolute w-[600px] h-[600px] rounded-full blur-[120px] opacity-20 -left-48 -top-48 bg-gradient-to-br from-primary to-transparent dark:opacity-5"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full blur-[100px] opacity-10 -right-24 -bottom-24 bg-gradient-to-tl from-tertiary to-transparent dark:opacity-5"></div>
    <div class="relative z-10 text-center flex flex-col items-center">
      <h2 class="text-surface text-[4rem] md:text-[6rem] font-black uppercase tracking-tighter leading-none mb-6">
        Radical <br /> Objectivity
      </h2>
      <div class="h-1 w-24 bg-primary mb-8"></div>
      <p class="text-surface/50 max-w-md text-sm uppercase tracking-[0.2em] font-medium">
        Designing systems that withstand the entropy of time and scale.
      </p>
    </div>
  </section>
</BaseLayout>
