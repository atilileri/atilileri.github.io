---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const items = await getCollection("uses");

const categories = ["hardware", "software", "desk", "sports"];
const categorizedItems = await Promise.all(
  categories.map(async (cat) => {
    const catItems = items
      .filter((item) => item.data.category === cat)
      .sort((a, b) => a.data.order - b.data.order);

    const renderedItems = await Promise.all(
      catItems.map(async (item) => {
        const { Content } = await render(item);
        return { ...item, Content };
      })
    );

    return {
      name: cat,
      items: renderedItems,
    };
  })
);
---

<BaseLayout title="Uses" currentPath="/uses">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <header class="mb-16">
      <h1 class="text-4xl font-bold font-space mb-4">Uses</h1>
      <p class="text-slate-400 text-lg">
        The gear and software that powers my engineering and adventures.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      {
        categorizedItems.map((cat) => (
          <section>
            <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-blue-500 mb-8 flex items-center gap-4">
              {cat.name}
              <span class="flex-grow h-px bg-slate-800" />
            </h2>

            <div class="grid grid-cols-1 gap-6">
              {cat.items.map((item) => (
                <div class="p-6 bg-slate-900/50 rounded-2xl border border-slate-800 hover:border-blue-500/30 transition-all group">
                  <div class="flex items-start gap-4">
                    {item.data.icon && (
                      <span class="material-symbols-outlined text-blue-400 p-2 bg-blue-500/10 rounded-lg">
                        {item.data.icon}
                      </span>
                    )}
                    <div>
                      <h3 class="font-bold mb-2 group-hover:text-blue-400 transition-colors">
                        {item.data.title}
                      </h3>
                      <div class="text-sm text-slate-400 prose prose-invert prose-sm">
                        <item.Content />
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
