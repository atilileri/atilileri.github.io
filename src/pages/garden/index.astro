---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Digital Garden" currentPath="/garden">
  <div class="px-6 md:px-12 max-w-[1440px] mx-auto">
    <!-- Hero Section -->
    <section class="mb-32">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1.5fr] gap-12 items-end">
        <div>
          <span class="block text-[0.75rem] uppercase tracking-[0.2em] font-bold mb-4 text-primary">Digital Garden</span>
          <h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-[0.9] text-on-surface">
            COLLECTED <br /> THOUGHTS.
          </h1>
        </div>
        <div class="pb-2">
          <p class="text-on-surface-variant text-lg leading-relaxed max-w-md">
            A nonlinear archive of research, experiments, and technical philosophy. Sharp precision meets organic growth.
          </p>
        </div>
      </div>
    </section>

    <!-- Featured Section: Bento Style -->
    <section class="mb-40">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-1 bg-surface-container-highest p-1">
        <!-- Bento Item 1 -->
        <div class="md:col-span-2 bg-surface-container-low p-12 min-h-[500px] flex flex-col justify-between group">
          <div class="flex justify-between items-start">
            <span class="text-xs font-black tracking-widest text-primary">01 // FEATURED</span>
            <span class="material-symbols-outlined text-on-surface opacity-20 group-hover:opacity-100 transition-opacity">arrow_outward</span>
          </div>
          <div>
            <h2 class="text-4xl font-bold tracking-tight mb-6">THE ARCHITECTURAL RATIO IN INTERFACE DESIGN.</h2>
            <div class="flex gap-4">
              <span class="text-[0.65rem] uppercase font-bold tracking-widest border border-on-surface/10 px-3 py-1">Theory</span>
              <span class="text-[0.65rem] uppercase font-bold tracking-widest border border-on-surface/10 px-3 py-1">12 Min Read</span>
            </div>
          </div>
        </div>
        <!-- Bento Item 2 -->
        <div class="bg-primary text-on-primary p-12 flex flex-col justify-between">
          <div>
            <span class="text-xs font-black tracking-widest opacity-60 text-[rgba(255,255,255,0.7)]">02 // LATEST</span>
            <h2 class="text-2xl font-bold tracking-tight mt-8">SYSTEMIC <br /> ENTROPY.</h2>
          </div>
          <p class="text-sm opacity-80 leading-relaxed text-[rgba(255,255,255,0.8)]">
            How software decays and what we can do to build resilient structures.
          </p>
        </div>
        <!-- Bento Item 3 -->
        <div class="bg-surface-container p-12 flex flex-col justify-center items-center text-center">
          <div class="w-full h-48 bg-surface-container-highest mb-8 overflow-hidden relative border border-on-surface/5">
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent"></div>
            <img
              class="w-full h-full object-cover mix-blend-multiply opacity-80 dark:mix-blend-screen"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuBgAQSVIFSbrKDEj6lfxiVuz5wdB4YqCiG46lpFlv9aU56Ism2upeoUw33qm2_83OoCrSPCPRADO-TiHNDn2JRiiqvmyDj1nUXsoq14WfbU6VDixSg9cBTvg5JTVCFAAyjaNr2_Ka0EPezFGUnV4o1ZHjCW09bEg9wnvsYl8wTlloO8S2XC_L2k82iUNp6aUqBuP1QZecQLKKQgayDohPHoEL4WhXO-z4-Uv3bSTUvrRrOwSjhSEQBkee9D1K_bR88A6YLhZOpNjCqS"
            />
          </div>
          <span class="text-xs font-black tracking-widest text-on-surface mb-2 block">03 // VISUALS</span>
          <h3 class="text-lg font-bold">GEOMETRIC TRUTH</h3>
        </div>
        <!-- Bento Item 4 -->
        <div class="md:col-span-2 bg-surface-container-low p-12 flex items-center justify-between">
          <div class="flex items-center gap-12">
            <span class="text-5xl font-black text-on-surface/10">04</span>
            <div>
              <h3 class="text-xl font-bold">RUST FOR FRONTEND ENGINEERS</h3>
              <p class="text-sm text-on-surface-variant mt-2">The paradigm shift in memory safety.</p>
            </div>
          </div>
          <span class="text-[0.65rem] uppercase font-bold tracking-widest px-3 py-1 bg-on-surface text-surface">Technical</span>
        </div>
      </div>
    </section>

    <!-- Hybrid List View -->
    <section class="max-w-4xl">
      <div class="mb-12">
        <h2 class="text-[0.75rem] uppercase font-black tracking-[0.3em] text-on-surface/40">Archive // Index</h2>
      </div>

      <!-- List Items -->
      <div class="group border-t border-on-surface/10 py-12 flex flex-col md:flex-row gap-8 items-baseline transition-all hover:bg-surface-container-low px-4 cursor-pointer">
        <span class="text-4xl font-black text-on-surface/10 group-hover:text-primary transition-colors">05</span>
        <div class="flex-1">
          <span class="text-[0.65rem] uppercase font-bold tracking-widest text-primary mb-2 block">March 2024</span>
          <h3 class="text-2xl font-bold tracking-tight group-hover:translate-x-2 transition-transform">THE MINIMALIST FALLACY IN MODERN WEB.</h3>
        </div>
        <div class="hidden md:block">
          <span class="text-sm font-medium text-on-surface-variant">/ Research</span>
        </div>
      </div>

      <div class="group border-t border-on-surface/10 py-12 flex flex-col md:flex-row gap-8 items-baseline transition-all hover:bg-surface-container-low px-4 cursor-pointer">
        <span class="text-4xl font-black text-on-surface/10 group-hover:text-primary transition-colors">06</span>
        <div class="flex-1">
          <span class="text-[0.65rem] uppercase font-bold tracking-widest text-primary mb-2 block">February 2024</span>
          <h3 class="text-2xl font-bold tracking-tight group-hover:translate-x-2 transition-transform">UNDERSTANDING SWISS TYPOGRAPHY.</h3>
        </div>
        <div class="hidden md:block">
          <span class="text-sm font-medium text-on-surface-variant">/ Design</span>
        </div>
      </div>

      <div class="group border-t border-on-surface/10 py-12 flex flex-col md:flex-row gap-8 items-baseline transition-all hover:bg-surface-container-low px-4 cursor-pointer">
        <span class="text-4xl font-black text-on-surface/10 group-hover:text-primary transition-colors">07</span>
        <div class="flex-1">
          <span class="text-[0.65rem] uppercase font-bold tracking-widest text-primary mb-2 block">January 2024</span>
          <h3 class="text-2xl font-bold tracking-tight group-hover:translate-x-2 transition-transform">THE DEATH OF THE BORDER RADIUS.</h3>
        </div>
        <div class="hidden md:block">
          <span class="text-sm font-medium text-on-surface-variant">/ Manifesto</span>
        </div>
      </div>

      <div class="border-t border-on-surface/10 pt-12 text-center md:text-left">
        <button class="inline-flex items-center gap-4 text-[0.75rem] font-black uppercase tracking-[0.2em] text-primary group">
          View Entire Archive 
          <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
        </button>
      </div>
    </section>
  </div>
</BaseLayout>
